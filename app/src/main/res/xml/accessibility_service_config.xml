<?xml version="1.0" encoding="utf-8"?>
<!-- notificationTimeout="100" (default) — confirmed correct via S0.7 re-investigation 
     on 2026-07-1X. An earlier apparent undercount was traced to Android Studio's 
     Logcat capture buffer silently dropping log lines during high-volume scrolling, 
     not to event coalescing. See SENSOR_PROGRESS.md for full corrected analysis. -->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeViewScrolled"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:canRetrieveWindowContent="false"
    android:notificationTimeout="100"
    android:packageNames="@null" />
