<?xml version="1.0" encoding="utf-8"?>
<!-- 
    notificationTimeout="20": tuned after S0.7 accuracy testing (2026-07-11).
    Original default of "100" caused ~9x undercount of scroll distance due to 
    event coalescing during rapid continuous scrolling — the OS was dropping 
    intermediate TYPE_VIEW_SCROLLED events within each 100ms debounce window.
    Value of 20 recovers ~86% of maximum measurable distance (vs. timeout=0) 
    while retaining some event debouncing to limit battery/CPU cost.
    Full test data and comparison table in SENSOR_PROGRESS.md.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeViewScrolled"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:canRetrieveWindowContent="false"
    android:notificationTimeout="20"
    android:packageNames="@null" />
